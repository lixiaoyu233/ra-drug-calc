.page{padding:12px 16px 90px;max-width:480px;margin:0 auto;min-height:100vh}

.bottom-nav{position:fixed;bottom:0;left:0;right:0;display:flex;background:rgba(250,250,252,.98);border-top:0.5px solid rgba(0,0,0,.1);padding:6px 0 20px;z-index:100}
.nav-item{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:2px;padding:2px 0}
.nav-icon{display:flex;align-items:center;justify-content:center;width:24px;height:24px}
.nav-label{font-size:11px;color:#86868b;font-weight:500}
.nav-item.active .nav-icon,.nav-item.active .nav-label{color:#007AFF}

.section{background:#fff;border-radius:14px;padding:18px;margin-bottom:12px;box-shadow:0 1px 3px rgba(0,0,0,.04),0 4px 12px rgba(0,0,0,.03)}
.section-header{font-size:13px;font-weight:600;color:#1d1d1f;margin-bottom:14px;letter-spacing:-.01em}

.ff{margin-bottom:12px}
.ff:last-child{margin-bottom:0}
.ff-lbl{display:block;font-size:12px;font-weight:500;color:#86868b;margin-bottom:5px;letter-spacing:-.01em}
.ff-val{display:block;font-size:16px;color:#1d1d1f;font-weight:500;padding:0 2px}
.ff-trigger{height:40px;line-height:40px;padding:0 14px;font-size:15px;color:#007AFF;background:#f5f5f7;border-radius:10px;box-sizing:border-box}
.ff-ipt-row{display:flex;align-items:center;background:#f5f5f7;border-radius:10px;padding:0 14px;height:40px;box-sizing:border-box}
.ff-ipt{flex:1;height:100%;font-size:15px;color:#1d1d1f;background:transparent;border:none;text-align:right;outline:none}
.ff-unit{font-size:13px;color:#86868b;margin-left:4px;flex-shrink:0}

.multi-picker-view{height:40px;line-height:40px;padding:0 14px;background:#f5f5f7;border-radius:10px;font-size:15px;box-sizing:border-box}
.mp-cat{color:#c7c7cc}

.mp-drug{font-size:15px;color:#1d1d1f;font-weight:500}

.hint{font-size:12px;color:#86868b;line-height:1.4;margin-top:4px}

.ios-btn{display:flex;align-items:center;justify-content:center;height:44px;border-radius:22px;font-size:15px;font-weight:500;text-align:center;padding:0 28px;border:none;transition:all .2s}
.ios-btn.primary{background:linear-gradient(180deg,#007AFF,#0066d6);color:#fff;box-shadow:0 2px 8px rgba(0,122,255,.3);flex:1}
.ios-btn.secondary{background:#f5f5f7;color:#007AFF;flex:1}
.ios-btn.small{height:34px;border-radius:17px;font-size:13px;background:#f5f5f7;color:#007AFF;padding:0 14px;display:inline-flex}
.ios-btn.add-btn{background:none;border:1.5px dashed #c7c7cc;color:#007AFF;height:40px;border-radius:20px;width:100%;font-size:14px;margin-bottom:10px;gap:4px;padding:0}
.add-icon{font-size:18px;font-weight:300}
.btn-row{display:flex;gap:10px;margin:6px 0}

.empty-state{text-align:center;padding:20px 0 10px;font-size:14px;color:#c7c7cc}

.presc-card{background:#f9f9fb;border-radius:12px;padding:12px 14px;margin-bottom:8px}
.presc-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:5px}
.presc-title{font-size:14px;font-weight:600;color:#1d1d1f;word-break:break-all}
.presc-del{font-size:13px;color:#ff3b30;padding:4px 8px;border-radius:6px}
.presc-body{display:flex;flex-direction:column;gap:2px}
.presc-info{font-size:13px;color:#86868b;line-height:1.5}

.result-card{background:linear-gradient(135deg,#f8faff,#f0f6ff);border-radius:14px;padding:18px;margin-bottom:12px;box-shadow:0 1px 3px rgba(0,0,0,.04),0 4px 12px rgba(0,0,0,.03);border-left:none}
.result-card.warn{background:linear-gradient(135deg,#fffbf5,#fff8e1)}
.rc-title{font-size:15px;font-weight:600;color:#1d1d1f;margin-bottom:10px}
.rc-row{display:flex;justify-content:space-between;align-items:center;padding:6px 0}
.rc-row+.rc-row{border-top:0.5px solid rgba(0,0,0,.04)}
.rc-label{font-size:14px;color:#86868b}
.rc-val{font-size:15px;font-weight:600;color:#1d1d1f}
.rc-val.blue{color:#007AFF;font-size:16px}
.rc-divider{height:0.5px;background:rgba(0,0,0,.06);margin:8px 0}
.rc-text{font-size:13px;color:#515154;line-height:1.7;white-space:pre-wrap;max-height:180px;padding:10px 12px;background:rgba(0,0,0,.03);border-radius:10px;font-family:-apple-system,SFMono-Regular,Menlo,monospace}

.gap-summary{display:block;font-size:12px;color:#86868b;margin-bottom:6px}
.gap-none{text-align:center;padding:14px 0;font-size:15px;color:#34c759;font-weight:500}
.gap-item{display:flex;align-items:center;gap:6px;padding:5px 0;flex-wrap:wrap;font-size:14px}
.gap-badge{background:#fff2f0;color:#ff3b30;font-size:12px;font-weight:600;padding:2px 8px;border-radius:4px}
.gap-text{font-size:13px;color:#515154}
.gap-arrow{color:#c7c7cc;font-size:14px}
.gap-total{text-align:center;padding:8px 0 4px;font-size:14px;color:#515154}
.gap-num{color:#ff3b30;font-weight:700;font-size:18px}
.gap-timeline{margin-top:8px;padding-top:8px}
.tl-item{display:flex;align-items:flex-start;padding:4px 0;position:relative}
.tl-line{width:2px;height:100%;background:#34c759;position:absolute;left:5px;top:14px}
.tl-line.gap{background:#ff9500}
.tl-dot{width:12px;height:12px;border-radius:50%;background:#007AFF;flex-shrink:0;margin-top:3px;z-index:1}
.tl-text{flex:1;display:flex;flex-direction:column;margin-left:12px}
.tl-date{font-size:13px;color:#1d1d1f}
.tl-days{font-size:12px;color:#86868b;margin-left:0;margin-top:0}
.tl-cum{display:block;font-size:12px;color:#007AFF;margin-top:2px}

.result-box{margin-top:10px;padding:16px;background:#f5f5f7;border-radius:12px;text-align:center}
.rb-label{font-size:13px;color:#86868b}
.rb-num{display:block;font-size:28px;font-weight:700;color:#007AFF;margin:4px 0;letter-spacing:-.02em}
.rb-sub{display:block;font-size:12px;color:#86868b;margin-top:2px}

.dir-group{display:flex;gap:8px}
.dir-btn{flex:1;height:36px;line-height:36px;text-align:center;border-radius:18px;font-size:14px;color:#515154;background:#f5f5f7}
.dir-btn.active{background:#007AFF;color:#fff;font-weight:500}

.calendar-wrap{background:#f5f5f7;border-radius:12px;padding:10px 8px;margin-bottom:8px}
.cal-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;padding:0 4px}
.cal-nav{font-size:16px;color:#007AFF;padding:4px 8px;font-weight:500}
.cal-title{font-size:15px;font-weight:600;color:#1d1d1f}
.cal-weekdays{display:flex;margin-bottom:4px}
.cal-wd{flex:1;text-align:center;font-size:12px;color:#86868b;padding:4px 0}
.cal-days{display:flex;flex-direction:column;gap:2px}
.cal-row{display:flex}
.cal-cell{flex:1;aspect-ratio:1;display:flex;align-items:center;justify-content:center}
.cal-cell.fill{visibility:hidden}
.cal-day{width:32px;height:32px;line-height:32px;text-align:center;border-radius:50%;font-size:14px;color:#1d1d1f}
.cal-day.today{font-weight:600;color:#007AFF}
.cal-day.selected{background:#007AFF;color:#fff;font-weight:600}

.gap-summary-box{margin-top:12px;padding:14px;background:#f8faff;border-radius:12px}
.gs-row{display:flex;justify-content:space-between;align-items:center;padding:4px 0}
.gs-lbl{font-size:13px;color:#86868b}
.gs-val{font-size:14px;font-weight:600;color:#1d1d1f}
.gs-val.blue{color:#007AFF}
.gs-val.warn{color:#ff9500}
.gs-val.red{color:#ff3b30}
.gs-val.green{color:#34c759}
.gs-val.orange{color:#ff9500}
.gs-divider{height:0.5px;background:rgba(0,0,0,.06);margin:6px 0}

.footer{text-align:center;font-size:12px;color:#c7c7cc;padding:20px 0 8px}

/* ====== Record Cards ====== */
.rec-card{background:#f9f9fb;border-radius:12px;padding:12px 14px;margin-bottom:10px}
.rec-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:6px}
.rec-abbr{font-size:16px;font-weight:700;color:#007AFF;letter-spacing:1px}
.rec-actions{display:flex;gap:8px}
.rec-btn{font-size:13px;padding:4px 8px;border-radius:6px}
.rec-btn.edit{color:#007AFF}
.rec-btn.del{color:#FF3B30}
.rec-body{display:flex;flex-direction:column;gap:2px;margin-bottom:6px}
.rec-info{font-size:12px;color:#86868b;line-height:1.4}
.rec-foot{display:flex;align-items:center;gap:8px;padding-top:6px;border-top:0.5px solid rgba(0,0,0,.04)}
.rec-days{font-size:14px;font-weight:600;color:#1d1d1f}
.rec-days.warn{color:#FF3B30}
.rec-badge{font-size:11px;color:#FF3B30;background:#FFF2F0;padding:2px 6px;border-radius:3px}

/* ====== Save Dialog ====== */
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.4);z-index:200}
.modal-box{position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);width:280px;background:#fff;border-radius:14px;z-index:201;overflow:hidden}
.modal-hd{text-align:center;font-size:16px;font-weight:600;color:#1d1d1f;padding:16px 16px 0}
.modal-body{padding:16px}
.modal-lbl{display:block;font-size:13px;color:#86868b;margin-bottom:6px}
.modal-ipt{display:block;width:100%;height:40px;line-height:40px;padding:0 12px;font-size:20px;font-weight:700;text-align:center;letter-spacing:3px;background:#f5f5f7;border:none;border-radius:10px;outline:none;color:#1d1d1f;text-transform:uppercase}
.modal-err{display:block;font-size:12px;color:#FF3B30;margin-top:4px;text-align:center}
.modal-btns{display:flex;border-top:0.5px solid rgba(0,0,0,.06)}
.modal-btn{flex:1;text-align:center;padding:14px 0;font-size:15px;cursor:pointer}
.modal-btn.cancel{color:#86868b}
.modal-btn.confirm{color:#007AFF;font-weight:600}
.modal-btn.confirm:active{background:#f5f5f7}

@media (prefers-color-scheme:dark){
.page{background:#1C1C1E;color:#F5F5F7}
.tab-bar{background:rgba(28,28,30,.95)}
.section{background:#2C2C2E;box-shadow:none}
.section-header{color:#98989D}
.ff-lbl{color:#98989D}
.ff-val{color:#F5F5F7}
.ff-trigger,.ff-ipt-row,.multi-picker-view{background:#3A3A3C;color:#F5F5F7}
.ff-trigger{color:#0A84FF}
.ff-ipt{color:#F5F5F7}
.ff-unit,.hint,.mp-cat{color:#98989D}
.mp-drug,.presc-title,.rc-title,.rc-val{color:#F5F5F7}
.presc-card,.rc-text,.calendar-wrap{background:#3A3A3C}
.presc-info,.rc-label,.gap-text,.rb-label,.gs-lbl{color:#98989D}
.result-card{background:#2C2C2E;box-shadow:none}
.result-card.warn{background:#3A2E1E}
.rc-row+.rc-row,.rc-divider,.gs-divider,.gap-timeline{border-color:#38383A}
.gap-summary-box{background:#1E2A3A}
.gap-badge{background:#4A2020;color:#FF453A}
.gap-none{color:#30D158}
.gap-total,.gap-arrow{color:#98989D}
.gap-num{color:#FF453A}
.tl-line{background:#30D158}
.tl-line.gap{background:#FF9F0A}
.tl-dot{background:#0A84FF}
.tl-cum{color:#0A84FF}
.tl-date{color:#F5F5F7}
.tl-days{color:#98989D}
.result-box{background:#3A3A3C}
.rb-num,.gs-val.blue,.rc-val.blue{color:#0A84FF}
.gs-val.green{color:#30D158}
.gs-val.warn{color:#FF9F0A}
.gs-val.red,.rc-val.red{color:#FF453A}
.gs-val.orange{color:#FF9F0A}
.empty-state{color:#48484A}
.btn-row .ios-btn.secondary,.dir-btn{background:#3A3A3C;color:#0A84FF}
.dir-btn.active{background:#0A84FF;color:#fff}
.dir-btn:not(.active){color:#98989D}
.presc-del{color:#FF453A}
.cal-nav{color:#0A84FF}
.cal-title{color:#F5F5F7}
.cal-wd{color:#98989D}
.cal-day{color:#F5F5F7}
.cal-day.today{color:#0A84FF}
.cal-day.selected{background:#0A84FF;color:#fff}
.ios-btn.primary{background:linear-gradient(180deg,#0A84FF,#0066CC)}
.ios-btn.secondary{background:#3A3A3C;color:#0A84FF}
.ios-btn.add-btn{border-color:#48484A;color:#0A84FF}
.bottom-nav{background:rgba(28,28,30,.98);border-color:#38383A}
.nav-label{color:#98989D}
.nav-item.active .nav-label{color:#0A84FF}
.rec-card{background:#3A3A3C}
.rec-abbr{color:#0A84FF}
.rec-info{color:#98989D}
.rec-days{color:#F5F5F7}
.rec-days.warn,.rec-badge{color:#FF453A}
.rec-badge{background:#4A2020}
.rec-foot{border-color:#38383A}
.modal-box{background:#2C2C2E}
.modal-hd{color:#F5F5F7}
.modal-lbl{color:#98989D}
.modal-ipt{background:#3A3A3C;color:#F5F5F7}
.modal-btn.cancel{color:#98989D}
.modal-btn.confirm{color:#0A84FF}
.modal-btns{border-color:#38383A}
.footer{color:#48484A}
}
